PORT=3000
SESSION_SECRET=replace-this-session-secret
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/bookmyshow?retryWrites=true&w=majority

# First user matching this email becomes admin when registering.
ADMIN_EMAIL=admin@example.com

# App URL for deployed links
APP_URL=http://localhost:3000

# Razorpay payment
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=rzp_secret_replace_me

# Email receipts. Use ONE provider from below.
EMAIL_FROM=CineGo <onboarding@resend.dev>
RESEND_API_KEY=re_replace_me
SENDGRID_API_KEY=SG_replace_me

# Gmail fallback (optional)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
